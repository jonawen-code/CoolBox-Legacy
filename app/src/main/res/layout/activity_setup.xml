<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="欢迎使用 CoolBox"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="让我们先完成基础设置"
            android:textSize="16sp"
            android:textColor="#666666" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="设置您的存储设备"
            android:textStyle="bold"
            android:textColor="#333333" />

        <!-- Dynamic Container for Device Rows -->
        <LinearLayout
            android:id="@+id/fridgeListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnAddFridge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ 添加新设备"
            android:textSize="14sp"
            android:textColor="#2196F3"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="分类设置（如：蔬菜、肉类、饮料）"
            android:textStyle="bold"
            android:textColor="#333333" />

        <EditText
            android:id="@+id/categoryInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="多个分类用逗号分隔"
            android:text="🥦 蔬菜水果, 🥩 肉蛋水产, 🥛 奶品饮料, 🥫 零食速食, 熟食剩菜" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#F5F5F5">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/syncEnabledSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="开启云端备份与远程同步"
                android:textSize="16sp"
                android:textColor="#333333" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="开启后可使用手机端微信小程序查看库存"
                android:textSize="12sp"
                android:textColor="#999999" />

            <EditText
                android:id="@+id/syncUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="云端服务器地址 (如: https://your-nas.com)"
                android:textSize="14sp"
                android:visibility="gone"
                android:text="http://192.168.31.94:3000/coolbox" />
        </LinearLayout>

        <Button
            android:id="@+id/completeBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:text="完成设置"
            android:background="#2196F3"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>
