<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="欢迎使用 CoolBox"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="让我们先完成基础设置"
            android:textSize="16sp"
            android:textColor="#666666" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="请选择入驻方式"
            android:textStyle="bold"
            android:textColor="#333333" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnStartNew"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="开启全新体验"
                android:background="#E3F2FD"
                android:textColor="#2196F3" />

            <Button
                android:id="@+id/btnTakeover"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="接管已有仓库"
                android:background="#FFF3E0"
                android:textColor="#FF9800" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/setupContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

        <LinearLayout
            android:id="@+id/sectionStorageSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="设置您的存储设备"
                android:textStyle="bold"
                android:textColor="#333333" />

            <!-- Dynamic Container for Device Rows -->
            <LinearLayout
                android:id="@+id/fridgeListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnAddFridge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ 添加新设备"
                android:textSize="14sp"
                android:textColor="#2196F3"
                android:background="?android:attr/selectableItemBackground"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionCategorySettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="分类设置（如：蔬菜、肉类、饮料）"
                android:textStyle="bold"
                android:textColor="#333333" />

            <EditText
                android:id="@+id/categoryInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="多个分类用逗号分隔"
                android:text="🥦 蔬菜水果, 🥩 肉蛋水产, 🥛 奶品饮料, 🥫 零食速食, 熟食剩菜" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#F5F5F5">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/syncEnabledSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="远程同步与备份"
                android:textSize="16sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/txtSyncHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="开启后可使用手机端微信小程序查看库存"
                android:textSize="12sp"
                android:textColor="#999999" />

            <EditText
                android:id="@+id/syncUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="云端服务器地址 (如: https://your-nas.com)"
                android:textSize="14sp"
                android:visibility="gone"
                android:text="http://192.168.31.94:3001/coolbox" />

            <TextView
                android:id="@+id/txtTakeoverHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="连接成功后，将自动从云端下载您的所有配置和数据。"
                android:textSize="12sp"
                android:textColor="#FF9800"
                android:visibility="gone" />

        </LinearLayout>

        <Button
            android:id="@+id/completeBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:text="完成设置"
            android:background="#2196F3"
            android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
