<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="实验室 (临期/过期测试)"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="点击下方按钮模拟食物过期，以测试首页的警告弹窗："
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnSimulateExpiry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="模拟：使第一个食物过期"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnSimulateExpiring"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="模拟：使第一个食物临期"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="当前食物列表 (用于验证):"
        android:textSize="14sp"
        android:textColor="#666666" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/testFoodList"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
